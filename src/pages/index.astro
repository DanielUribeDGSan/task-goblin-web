---
import { ClientRouter } from "astro:transitions";
import { TaskNotchLanding } from "../components/dashboard/TaskNotchLanding";
import { FloatingChat } from "../components/FloatingChat";
import { GlobalLoader } from "../components/GlobalLoader";
import "../styles/global.css";

const title = "TaskNotch — Tu menú interactivo y productivo en Mac";
const description =
  "TaskNotch es la barra interactiva que optimiza tu día a día en Mac: borrador mágico de objetos con IA, conversor de imágenes a WebP, extractor de texto OCR, traducción de pantalla y más. Descárgala ya.";
const ogImage = `${Astro.site}/icon/TaskNotch.png`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/icon/TaskNotch.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO: Google, Bing (Edge), Safari -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="TaskNotch, Notch, interactivo, barra de herramientas, borrador mágico, IA, OCR, screenshot to text, traducción de pantalla, Mac, utilidades"
    />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="TaskNotch" />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Sitemap para buscadores -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body class="antialiased font-sans bg-[#202020]">
    <TaskNotchLanding client:load />
    <FloatingChat client:load appType="task-notch" />

    <!-- JSON-LD: ayuda a Google a mostrar la app en resultados (SoftwareApplication, WebSite, Organization) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebSite",
            "@id": "https://task-goblin.com/#website",
            url: "https://task-goblin.com/",
            name: "TaskNotch",
            description: description,
            publisher: {
              "@type": "Organization",
              name: "TaskNotch",
              logo: {
                "@type": "ImageObject",
                url: ogImage,
              },
            },
          },
          {
            "@type": "SoftwareApplication",
            "@id": "https://task-goblin.com/#software",
            name: "TaskNotch",
            applicationCategory: "UtilitiesApplication",
            operatingSystem: "macOS",
            description: description,
            image: ogImage,
            offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
            featureList: [
              "AI Magic Eraser",
              "Screenshot to Text OCR",
              "AI Screen Translation",
              "Local PDF Tools",
              "Quick settings",
            ],
          },
        ],
      })}
    />
  </body>
</html>
